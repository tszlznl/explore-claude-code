{
  // 权限控制 Claude 无需询问即可使用的工具。
  // 每个条目是一个 glob 模式，匹配工具 + 参数。
  "permissions": {
    "allow": [
      // 允许 Claude 读取任何文件而无需提示
      "Read",
      // 允许 Claude 自由搜索文件
      "Glob",
      "Grep",
      // 允许 Claude 运行测试套件
      "Bash(npm test)",
      "Bash(npm run lint)",
      // 允许 Claude 运行开发服务器
      "Bash(npm run dev)",
      // 允许 git status 和 diff（只读 git）
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      // 绝不允许 Claude 推送到远程
      "Bash(git push*)",
      // 绝不允许 Claude 安装依赖包而无需询问
      "Bash(npm install*)",
      // 阻止破坏性 git 命令
      "Bash(git reset --hard*)",
      "Bash(git clean*)"
    ]
  },

  // API 配置
  "model": "claude-sonnet-4-6",
  "maxTokens": 16384,

  // 钩子在 Claude 工作流的特定时间点运行自定义脚本。
  // 查看 .claude/hooks/ 获取完整概览和示例脚本。
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/my-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint --fix",
            "async": true
          }
        ]
      }
    ]
  }
}
