{
  // .claude-plugin/plugin.json — 插件清单
  //
  // 此文件定义你的插件身份。Claude Code 使用它
  // 在插件管理器中显示你的插件，命名你的技能，
  // 并跟踪版本以进行更新。
  //
  // 这是唯一放入 .claude-plugin/ 内的文件。
  // 所有组件目录（skills/、agents/、hooks/ 等）
  // 位于插件根目录，而不是此目录内。

  // ── 必填字段 ────────────────────────────────────────────

  // 唯一标识符。也成为技能命名空间前缀。
  // 此插件中名为 "review" 的技能 → /my-plugin:review
  "name": "my-plugin",

  // 在浏览或安装时显示在插件管理器中。
  "description": "一个入门插件，展示清单格式和可用字段",

  // 语义化版本：major.minor.patch
  // 破坏性更改 bump major，功能 bump minor，修复 bump patch。
  // Claude Code 使用这个检测更新。
  "version": "1.0.0",

  // ── 可选元数据 ──────────────────────────────────────────

  // 归属。显示在插件详情中。
  "author": {
    "name": "你的名字",
    "email": "you@example.com"
  },

  // 插件文档 URL
  "homepage": "https://github.com/your-org/my-plugin#readme",

  // 源代码仓库
  "repository": "https://github.com/your-org/my-plugin",

  // SPDX 许可证标识符（MIT、Apache-2.0 等）
  "license": "MIT",

  // 市场中用于发现和分类的标签
  "keywords": ["starter", "example", "scaffold"]

  // ── 组件覆盖（高级） ─────────────────────────────
  //
  // 默认情况下，Claude Code 通过扫描
  // 插件根目录的标准目录来发现组件：
  //   skills/    → Agent Skills
  //   commands/  → 斜杠命令
  //   agents/    → 自定义代理
  //   hooks/     → hooks.json 事件处理程序
  //   .mcp.json  → MCP 服务器配置
  //   .lsp.json  → LSP 服务器配置
  //
  // 你可以使用显式路径覆盖这些：
  //
  //   "commands": ["./commands/core/", "./commands/extra/review.md"],
  //   "agents": ["./agents/security-reviewer.md"],
  //   "hooks": { "PostToolUse": [...] },
  //   "mcpServers": { "my-db": { "command": "..." } },
  //   "lspServers": { "go": { "command": "gopls" } }
  //
  // 大多数插件不需要这些 — 默认值工作正常。
}